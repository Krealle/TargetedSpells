<!-- this is CooldownViewerEssentialItemTemplate with minor modifications -->
<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="TargetedSpellsFrameTemplate" mixin="TargetedSpellsMixin" virtual="true" ignoreParentAlpha="true" enableMouse="false" propagateMouseInput="Both">
        <Layers>
            <Layer level="ARTWORK">
                <Texture parentKey="Icon" setAllPoints="true" />
                <MaskTexture atlas="UI-HUD-CoolDownManager-Mask" setAllPoints="true">
                    <MaskedTextures>
                        <MaskedTexture childKey="Icon" />
                    </MaskedTextures>
                </MaskTexture>
            </Layer>
            <Layer level="OVERLAY">
                <Texture atlas="UI-HUD-CoolDownManager-IconOverlay" parentKey="Overlay">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="-15" y="15" />
                        <Anchor point="BOTTOMRIGHT" x="15" y="-15" />
                    </Anchors>
                </Texture>
                <Texture parentKey="InterruptIcon" hidden="true" setAllPoints="true" file="Interface\TARGETINGFRAME\UI-RaidTargetingIcon_7.blp">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="4" y="-4" />
                        <Anchor point="BOTTOMRIGHT" x="-4" y="4" />
                    </Anchors>
                </Texture>
                <FontString hidden="true" parentKey="InterruptSource" font="GameFontHighlightSmall" justifyV="TOP" setAllPoints="true">
                    <Anchors>
                        <Anchor point="TOP" relativePoint="TOP">
                            <Offset>
                                <AbsDimension x="0" y="5" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
                <!-- Solid border strips -->
                <Texture parentKey="BorderSolidTop" hidden="true" file="Interface\Buttons\WHITE8x8">
                    <Color r="1" g="1" b="1" a="0.8" />
                    <Size>
                        <AbsDimension x="0" y="1" />
                    </Size>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT" />
                        <Anchor point="TOPRIGHT" relativePoint="TOPRIGHT" />
                    </Anchors>
                </Texture>
                <Texture parentKey="BorderSolidBottom" hidden="true" file="Interface\Buttons\WHITE8x8">
                    <Color r="1" g="1" b="1" a="0.8" />
                    <Size>
                        <AbsDimension x="0" y="1" />
                    </Size>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT" />
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT" />
                    </Anchors>
                </Texture>
                <Texture parentKey="BorderSolidLeft" hidden="true" file="Interface\Buttons\WHITE8x8">
                    <Color r="1" g="1" b="1" a="0.8" />
                    <Size>
                        <AbsDimension x="1" y="0" />
                    </Size>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT" />
                        <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT" />
                    </Anchors>
                </Texture>
                <Texture parentKey="BorderSolidRight" hidden="true" file="Interface\Buttons\WHITE8x8">
                    <Color r="1" g="1" b="1" a="0.8" />
                    <Size>
                        <AbsDimension x="1" y="0" />
                    </Size>
                    <Anchors>
                        <Anchor point="TOPRIGHT" relativePoint="TOPRIGHT" />
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT" />
                    </Anchors>
                </Texture>
                <!-- Slice border corners -->
                <Texture parentKey="BorderTopLeft" hidden="true" />
                <Texture parentKey="BorderTopRight" hidden="true" />
                <Texture parentKey="BorderBottomLeft" hidden="true" />
                <Texture parentKey="BorderBottomRight" hidden="true" />
                <!-- Slice border edges, statically anchored to their adjacent corners -->
                <Texture parentKey="BorderTop" hidden="true">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.BorderTopLeft" relativePoint="TOPRIGHT" />
                        <Anchor point="TOPRIGHT" relativeKey="$parent.BorderTopRight" relativePoint="TOPLEFT" />
                    </Anchors>
                </Texture>
                <Texture parentKey="BorderBottom" hidden="true">
                    <Anchors>
                        <Anchor point="BOTTOMLEFT" relativeKey="$parent.BorderBottomLeft" relativePoint="BOTTOMRIGHT" />
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.BorderBottomRight" relativePoint="BOTTOMLEFT" />
                    </Anchors>
                </Texture>
                <Texture parentKey="BorderLeft" hidden="true">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.BorderTopLeft" relativePoint="BOTTOMLEFT" />
                        <Anchor point="BOTTOMLEFT" relativeKey="$parent.BorderBottomLeft" relativePoint="TOPLEFT" />
                    </Anchors>
                </Texture>
                <Texture parentKey="BorderRight" hidden="true">
                    <Anchors>
                        <Anchor point="TOPRIGHT" relativeKey="$parent.BorderTopRight" relativePoint="BOTTOMRIGHT" />
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.BorderBottomRight" relativePoint="TOPRIGHT" />
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Cooldown parentKey="Cooldown" setAllPoints="true" minimumCountdownDuration="0">
                <SwipeTexture file="Interface\HUD\UI-HUD-CoolDownManager-Icon-Swipe">
                    <Color r="0" g="0" b="0" a="0.7" />
                </SwipeTexture>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString hidden="true" parentKey="DurationText" font="GameFontHighlightHugeOutline" justifyH="CENTER" setAllPoints="true">
                        </FontString>
                    </Layer>
                </Layers>
            </Cooldown>
            <StatusBar parentKey="Bar" ignoreParentAlpha="true" minValue="0" maxValue="1" />
        </Frames>
        <Scripts>
            <OnLoad method="OnLoad" />
            <OnSizeChanged method="OnSizeChanged" />
            <OnUpdate method="OnUpdate" />
        </Scripts>
    </Frame>
</Ui>